
QWEN_MODEL=qwen2.5
LLAMA_MODEL=llama3.1:8b
GEMMA_MODEL=gemma4:e4b

# not obligatory (just for better worker logs without warnings)
HF_TOKEN=your_huggingface_token_here

# LightOCR memory/quality knobs for the real worker.
# P2MC_LIGHTOCR_TARGET_LONGEST controls rendered page/image size:
# higher values improve OCR on small text/tables but use more RAM.
# P2MC_LIGHTOCR_MAX_NEW_TOKENS controls how much OCR text can be generated:
# higher values help dense pages/large tables but increase memory and runtime.
#
# Suggested profiles:
# - Constrained local Docker or exit code 137: 768 / 512
# - Safe default for local testing: 1024 / 1024
# - Linux VM with ~60 GB RAM: 1540 / 4096
# - Maximum extraction if the VM stays stable: 1540 / 8192
P2MC_LIGHTOCR_TARGET_LONGEST=1024
P2MC_LIGHTOCR_MAX_NEW_TOKENS=1024
# P2MC_LIGHTOCR_MODEL_ID=lightonai/LightOnOCR-2-1B
