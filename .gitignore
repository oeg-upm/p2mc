ignore
logs
# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyright/
.coverage
.coverage.*
htmlcov/
.ipynb_checkpoints/

# Python virtual environments
.venv/
venv/
env/
ENV/
backend/.venv/
frontend/.venv/

# Packaging/build artifacts
build/
dist/
*.egg-info/
.eggs/

# Poetry
# poetry.lock must be committed
poetry.toml

# Environment variables and secrets
.env
.env.*
!.env.example

# Streamlit secrets
frontend/.streamlit/secrets.toml

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo
*~

# Operating-system files
.DS_Store
Thumbs.db
desktop.ini

# Logs and temporary files
*.log
tmp/
temp/
.cache/

# Runtime-generated backend data
backend/data/raw/*
backend/data/interim/*
backend/data/processed/*
backend/generated_modelcards/*

# Keep empty runtime directories in Git
!backend/data/raw/.gitkeep
!backend/data/interim/.gitkeep
!backend/data/processed/.gitkeep
!backend/generated_modelcards/.gitkeep

# Local model/download caches
backend/huggingface-cache/
backend/.huggingface/
huggingface-cache/
ollama-data/
docker-data/

# Docker overrides created only for a developer machine
docker-compose.override.yml
