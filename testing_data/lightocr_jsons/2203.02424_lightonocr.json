      "tables": [
        {
          "html": "<table>\n  <tr>\n    <th colspan=\"2\">Algorithm 1: Generating node embeddings using RR-GCN layers</th>\n  </tr>\n  <tr>\n    <td colspan=\"2\">Inputs: relations $\\mathcal{R}$ , per-relation node neighbours $\\mathcal{N}$ , embedding size $e$ , number of layers $n$ , seed $s$ , nodes $\\mathcal{V}$ </td>\n  </tr>\n  <tr>\n    <td colspan=\"2\">Output: Matrix $\\in \\mathbb{R}^{|\\mathcal{V}| \\times e}$ </td>\n  </tr>\n  <tr>\n    <td>1</td>\n    <td>Function EMBED-RRGCN-PPV( $e, s, n$ ):</td>\n  </tr>\n  <tr>\n    <td>2</td>\n    <td> $H \\leftarrow \\text{NORMAL}(|\\mathcal{V}| \\times e, s, \\sigma^2 = \\frac{1}{e})$ </td>\n  </tr>\n  <tr>\n    <td>3</td>\n    <td> $S \\leftarrow \\text{RANDOM-LIST}(s, |\\mathcal{R}| + 1)$ </td>\n  </tr>\n  <tr>\n    <td>4</td>\n    <td> $H \\leftarrow (\\text{RRGCN-CONV}(S, e, H))^+$ </td>\n  </tr>\n  <tr>\n    <td>5</td>\n    <td> $P \\leftarrow \\text{PPV}(H, \\mathcal{N})$ </td>\n  </tr>\n  <tr>\n    <td>6</td>\n    <td>repeat $n - 1$ times</td>\n  </tr>\n  <tr>\n    <td>7</td>\n    <td> $H \\leftarrow (\\text{RRGCN-CONV}(S, e, H))^+$ </td>\n  </tr>\n  <tr>\n    <td>8</td>\n    <td> $P \\leftarrow \\text{RRGCN-CONV}(S, e, P)$ </td>\n  </tr>\n  <tr>\n    <td>9</td>\n    <td> $P \\leftarrow \\text{PPV}(P, \\mathcal{N})$ </td>\n  </tr>\n  <tr>\n    <td>10</td>\n    <td>return $[h \\parallel p]$ </td>\n  </tr>\n</table>"
        },
        {
          "html": "<table>\n  <tr>\n    <th colspan=\"2\">Algorithm 2: RR-GCN Message Passing</th>\n  </tr>\n  <tr>\n    <td colspan=\"2\">Inputs: list of seeds $S$ , embedding size $e$ , node representations $H$ </td>\n  </tr>\n  <tr>\n    <td colspan=\"2\">Output: Matrix $\\in \\mathbb{R}^{|\\mathcal{V}| \\times e}$ </td>\n  </tr>\n  <tr>\n    <td>1</td>\n    <td>Function RRGCN-CONV( $S, e, H$ ):</td>\n  </tr>\n  <tr>\n    <td>2</td>\n    <td> $X \\leftarrow O_{e \\times e}$ </td>\n  </tr>\n  <tr>\n    <td>3</td>\n    <td>foreach $r \\in \\mathcal{R}$ do</td>\n  </tr>\n  <tr>\n    <td>4</td>\n    <td> $W_r \\leftarrow \\text{RANDOM-UNIFORM}(e \\times e, S_r)$ </td>\n  </tr>\n  <tr>\n    <td>5</td>\n    <td> $x_i \\leftarrow h_i + \\sum_{j \\in \\mathcal{N}_r(i)} \\frac{1}{|\\mathcal{N}_r(i)|} W_r h_j^{(l)}$ </td>\n  </tr>\n  <tr>\n    <td>6</td>\n    <td> $W_0 \\leftarrow \\text{GLOROT-UNIFORM}(e \\times e, S_0)$ </td>\n  </tr>\n  <tr>\n    <td>7</td>\n    <td> $x_i \\leftarrow h_i + W_0 h_i^{(l)}$ </td>\n  </tr>\n  <tr>\n    <td>8</td>\n    <td>return $X$ </td>\n  </tr>\n</table>"
        }
      ]
    },
