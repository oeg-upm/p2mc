          "html": "<table>\n  <thead>\n    <tr>\n      <th>Method</th>\n      <th>Score Function</th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n      <td>TransE</td>\n      <td> $-\\|\\mathbf{h} + \\mathbf{r} - \\mathbf{t}\\|$ </td>\n      <td> $\\mathbf{h}, \\mathbf{r}, \\mathbf{t} \\in \\mathbb{R}^k$ </td>\n    </tr>\n    <tr>\n      <td>TransH</td>\n      <td> $-\\|(\\mathbf{h} - \\mathbf{w}_r^\\top \\mathbf{h} \\mathbf{w}_r) + \\mathbf{r} - (\\mathbf{t} - \\mathbf{w}_r^\\top \\mathbf{t} \\mathbf{w}_r)\\|$ </td>\n      <td> $\\mathbf{h}, \\mathbf{t}, \\mathbf{r}, \\mathbf{w}_r \\in \\mathbb{R}^k$ </td>\n    </tr>\n    <tr>\n      <td>TransR</td>\n      <td> $-\\|\\mathbf{M}_r \\mathbf{h} + \\mathbf{r} - \\mathbf{M}_r \\mathbf{t}\\|$ </td>\n      <td> $\\mathbf{h}, \\mathbf{t} \\in \\mathbb{R}^k, \\mathbf{M}_r \\in \\mathbb{R}^{k \\times d}$ </td>\n    </tr>\n    <tr>\n      <td>TransD</td>\n      <td> $-\\|(\\mathbf{w}_r \\mathbf{w}_h^\\top + \\mathbf{I}) \\mathbf{h} + \\mathbf{r} - (\\mathbf{w}_r \\mathbf{w}_r^\\top + \\mathbf{I}) \\mathbf{t}\\|$ </td>\n      <td> $\\mathbf{h}, \\mathbf{t}, \\mathbf{w}_h \\mathbf{w}_r \\in \\mathbb{R}^k, \\mathbf{r}, \\mathbf{w}_r \\in \\mathbb{R}^d$ </td>\n    </tr>\n    <tr>\n      <td>TransG</td>\n      <td> $\\sum_i \\pi_i^* \\exp\\left(-\\frac{\\|\\mu_h + \\mu_i - \\mu_i\\|}{\\sigma_h^2 + \\sigma_i^2}\\right)$ </td>\n      <td> $\\mathbf{h} \\sim \\mathcal{N}(\\mu_h, \\sigma_h^2 \\mathbf{I}), \\mathbf{t} \\sim \\mathcal{N}(\\mu_i, \\Sigma_i), \\mu_h, \\mu_i \\in \\mathbb{R}^k$ </td>\n    </tr>\n    <tr>\n      <td>TranSparse-S</td>\n      <td> $-\\|\\mathbf{M}_r(\\theta_r) \\mathbf{h} + \\mathbf{r} - \\mathbf{M}_r(\\theta_r) \\mathbf{t}\\|_{1/2}^2 - \\|\\mathbf{M}_r^1(\\theta_r^1) \\mathbf{h} + \\mathbf{r} - \\mathbf{M}_r^2(\\theta_r^2) \\mathbf{t}\\|_{1/2}^2$ </td>\n      <td> $\\mathbf{h}, \\mathbf{t} \\in \\mathbb{R}^k, \\mathbf{r} \\in \\mathbb{R}^d, \\mathbf{M}_r(\\theta_r) \\in \\mathbb{R}^{k \\times d}, \\mathbf{M}_r^1(\\theta_r^1), \\mathbf{M}_r^2(\\theta_r^2) \\in \\mathbb{R}^{k \\times d}$ </td>\n    </tr>\n    <tr>\n      <td>DistMult</td>\n      <td> $(\\mathbf{r}, \\mathbf{h}, \\mathbf{t})$ </td>\n      <td> $\\mathbf{h}, \\mathbf{r}, \\mathbf{t} \\in \\mathbb{R}^k$ </td>\n    </tr>\n    <tr>\n      <td>ConvKB</td>\n      <td> $\\text{concat}(g[(\\mathbf{h}, \\mathbf{r}, \\mathbf{t}] * \\omega)) \\mathbf{w}$ </td>\n      <td> $\\mathbf{h}, \\mathbf{r}, \\mathbf{t} \\in \\mathbb{R}^k$ </td>\n    </tr>\n    <tr>\n      <td>ComplEx</td>\n      <td> $\\Re(\\mathbf{r}, \\mathbf{h}, \\mathbf{t})$ </td>\n      <td> $\\mathbf{h}, \\mathbf{r}, \\mathbf{t} \\in \\mathbb{C}^k$ </td>\n    </tr>\n    <tr>\n      <td>ConvE</td>\n      <td> $(\\sigma(\\text{vec}(\\sigma([\\mathbf{r}, \\mathbf{h}] * \\Omega)) \\mathbf{W}), \\mathbf{t})$ </td>\n      <td> $\\mathbf{h}, \\mathbf{r}, \\mathbf{t} \\in \\mathbb{R}^k$ </td>\n    </tr>\n    <tr>\n      <td>RotatE</td>\n      <td> $-\\|\\mathbf{h} \\circ \\mathbf{r} - \\mathbf{t}\\|^2$ </td>\n      <td> $\\mathbf{h}, \\mathbf{r}, \\mathbf{t} \\in \\mathbb{C}^k, |\\mathbf{r}_i| = 1$ </td>\n    </tr>\n    <tr>\n      <td>REFE</td>\n      <td> $-\\text{arctanh}(\\|-(\\mathbf{h}, \\text{Ref}(\\mathbf{r})) \\oplus^c \\mathbf{t}\\|)$ </td>\n      <td> $\\mathbf{h}, \\mathbf{r}, \\mathbf{t} \\in \\mathbb{R}^k$ </td>\n    </tr>\n    <tr>\n      <td>HAKE</td>\n      <td> $\\text{RotatE} - \\|\\sin((\\mathbf{h} + \\mathbf{r} - \\mathbf{t})/2)\\|_1$ </td>\n      <td> $\\mathbf{h}, \\mathbf{r}, \\mathbf{t} \\in \\mathbb{R}^k$ </td>\n    </tr>\n    <tr>\n      <td>ComplEx-DURA</td>\n      <td> $\\text{ComplEx} - (\\mathbf{h}, \\mathbf{r})^2 - \\|\\mathbf{t}\\|^2$ </td>\n      <td> $\\mathbf{h}, \\mathbf{r}, \\mathbf{t} \\in \\mathbb{C}^k$ </td>\n    </tr>\n  </tbody>\n</table>"
